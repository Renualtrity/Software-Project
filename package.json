{
  "name": "mcga-pro",
  "version": "2.0.0",
  "description": "Minecraft AI Mod Generator - Desktop Edition",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --dir",
    "build-installer": "electron-builder --win",
    "dev": "electron . --dev"
  },
  "author": "MCGA Pro Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "decompress": "^4.2.1"
  },
  "build": {
    "appId": "com.mcga.pro",
    "productName": "MCGA Pro",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "index.html",
      "css/**/*",
      "js/**/*",
      "core/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": "portable"
    },
    "publish": null
  }
}